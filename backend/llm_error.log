  "properties": {
    "improved_wording": {
      "description": "Suggested improved legal wording to replace the clause. State 'No change needed' if acceptable.",
      "title": "Improved Wording",
      "type": "string"
    },
    "counter_terms": {
      "description": "List of negotiation points or counter-terms to present to the other party.",
      "items": [
        "The Client's total aggregate liability shall not exceed INR 50,000.",
        "The Service Provider's liability under this agreement shall be limited to INR 50,000 or the amount paid by the Client for the Services provided during the term of this Agreement."
      ],
      "title": "Counter Terms",
      "type": "array"
    }
  },
  "required": [
    "improved_wording",
    "counter_terms"
  ],
  "title": "NegotiationInfo",
  "type": "object"
}
